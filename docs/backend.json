{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "photoURL": { "type": "string", "format": "uri", "description": "URL of the user's profile picture." },
        "role": { "type": "string", "enum": ["patient", "therapist"], "description": "The user's role in the application." }
      },
      "required": ["uid", "email", "role"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Represents a scheduled appointment between a patient and a therapist.",
      "type": "object",
      "properties": {
        "patientId": { "type": "string" },
        "patientName": { "type": "string" },
        "therapistId": { "type": "string" },
        "therapistName": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["confirmed", "cancelled"] }
      },
      "required": ["patientId", "therapistId", "startTime", "endTime", "status"]
    },
    "TherapistSchedule": {
      "title": "Therapist Schedule",
      "description": "Stores a therapist's work schedule configuration.",
      "type": "object",
      "properties": {
        "workingDays": {
          "type": "array",
          "items": { "type": "number" },
          "description": "Array of numbers for working days (0=Sun, 1=Mon, ...)"
        },
        "workingHours": {
          "type": "object",
          "properties": {
            "start": { "type": "string", "description": "Start time in HH:MM format." },
            "end": { "type": "string", "description": "End time in HH:MM format." }
          },
          "required": ["start", "end"]
        },
        "sessionDurationMinutes": { "type": "number" },
        "mandatoryBreakMinutes": { "type": "number", "default": 15 },
        "lunchBreak": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "start": { "type": "string", "description": "Start time in HH:MM format." },
            "end": { "type": "string", "description": "End time in HH:MM format." }
          }
        },
        "manualSlots": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "start": { "type": "string", "format": "date-time" },
              "end": { "type": "string", "format": "date-time" }
            }
          }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "User profile documents, keyed by user ID."
    },
    "/therapists/{therapistId}/schedule": {
        "schema": { "$ref": "#/entities/TherapistSchedule" },
        "description": "Therapist schedule documents, keyed by therapist ID."
    },
    "/appointments/{appointmentId}": {
      "schema": { "$ref": "#/entities/Appointment" },
      "description": "Appointment documents."
    }
  }
}


{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "photoURL": { "type": "string", "format": "uri", "description": "URL of the user's profile picture." },
        "role": { "type": "string", "enum": ["patient", "therapist", "trainee", "supervisor"], "description": "The user's role in the application." },
        "supervisionStatus": {
          "type": "string",
          "enum": ["unsupervised", "pending", "approved", "revoked"],
          "description": "Supervision status for trainees."
        },
        "supervisorId": { "type": "string", "description": "The UID of the supervising therapist." },
        "licenseNumber": { "type": "string", "description": "License number for supervisors." },
        "degree": { "type": "string", "description": "Degree obtained by the trainee." },
        "institution": { "type": "string", "description": "Institution where the degree was obtained." },
        "graduationYear": { "type": "number", "description": "Year of graduation." },
        "bio": { "type": "string", "description": "A short biography." },
        "areasOfInterest": { "type": "array", "items": { "type": "string" }, "description": "Areas of interest for trainees." }
      },
      "required": ["uid", "email", "role"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Represents a scheduled appointment between a patient and a therapist.",
      "type": "object",
      "properties": {
        "patientId": { "type": "string" },
        "patientName": { "type": "string" },
        "therapistId": { "type": "string" },
        "therapistName": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["confirmed", "cancelled"] }
      },
      "required": ["patientId", "therapistId", "startTime", "endTime", "status"]
    },
    "TherapistSchedule": {
      "title": "Therapist Schedule",
      "description": "Stores a therapist's work schedule configuration.",
      "type": "object",
      "properties": {
        "workingDays": {
          "type": "array",
          "items": { "type": "number" },
          "description": "Array of numbers for working days (0=Sun, 1=Mon, ...)"
        },
        "workingHours": {
          "type": "object",
          "properties": {
            "start": { "type": "string", "description": "Start time in HH:MM format." },
            "end": { "type": "string", "description": "End time in HH:MM format." }
          },
          "required": ["start", "end"]
        },
        "sessionDurationMinutes": { "type": "number" },
        "mandatoryBreakMinutes": { "type": "number", "default": 15 },
        "lunchBreak": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "start": { "type": "string", "description": "Start time in HH:MM format." },
            "end": { "type": "string", "description": "End time in HH:MM format." }
          }
        },
        "manualSlots": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "start": { "type": "string", "format": "date-time" },
              "end": { "type": "string", "format": "date-time" }
            }
          }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "SupervisionRequest": {
      "title": "Supervision Request",
      "description": "A request from a trainee to a supervisor for supervision.",
      "type": "object",
      "properties": {
        "traineeId": { "type": "string" },
        "supervisorId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["traineeId", "supervisorId", "status", "createdAt"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "User profile documents, keyed by user ID."
    },
    "/therapists/{therapistId}/schedule": {
        "schema": { "$ref": "#/entities/TherapistSchedule" },
        "description": "Therapist and approved trainee schedule documents, keyed by user ID."
    },
    "/appointments/{appointmentId}": {
      "schema": { "$ref": "#/entities/Appointment" },
      "description": "Appointment documents."
    },
    "/supervisionRequests/{requestId}": {
      "schema": { "$ref": "#/entities/SupervisionRequest" },
      "description": "Supervision request documents."
    }
  }
}

#updates roles

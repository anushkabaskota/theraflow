rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read and write to their own profile.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Rules for appointments
    match /appointments/{appointmentId} {
      // Anyone authenticated can create an appointment, but only for themselves.
      allow create: if request.auth != null && request.auth.uid == request.resource.data.patientId;
      
      // The patient or the therapist can read the appointment details.
      allow read: if request.auth != null && (request.auth.uid == resource.data.patientId || request.auth.uid == resource.data.therapistId);
      
      // Appointments cannot be updated or deleted by clients for now.
      allow update, delete: if false;
    }
    
    // Therapists can manage their own schedule
    match /therapists/{therapistId}/schedule {
      allow read, write: if request.auth != null && request.auth.uid == therapistId;
    }
  }
}
